{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/feature-branch.sh",
            "shell": "bash",
            "timeout": 10,
            "statusMessage": "Checking branch..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/changelog.sh",
            "shell": "bash",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ]
  }
}
